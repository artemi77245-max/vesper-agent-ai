# Ключ OpenRouter (взять бесплатно на https://openrouter.ai/keys)
OPENROUTER_API_KEY=твой_ключ_здесь

# Модель OpenRouter. По умолчанию — бесплатная с поддержкой tool calling.
# Другие варианты смотри на https://openrouter.ai/models (фильтр ":free" + "tools").
VESPER_MODEL=openai/gpt-oss-20b:free

# Рабочая папка агента — тут он читает и пишет файлы
VESPER_WORKSPACE=./workspace

# Прокси для доступа к OpenRouter (например NekoBox).
# Формат: socks5://127.0.0.1:2080  или  http://127.0.0.1:2080
# Оставь пустым или удали строку, если прокси не нужен.
PROXY_URL=socks5://127.0.0.1:2080
